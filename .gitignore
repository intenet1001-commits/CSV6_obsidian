# Obsidian workspace state (per-machine, not portable)
.obsidian/workspace*.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/graph.json
.obsidian/.trash/

# bkit / OMC agent state (별개 시스템, vault 콘텐츠 아님)
.bkit/
.omc/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor backups
*.swp
*~
.#*

# Obsidian Bases (개인 뷰 정의)
*.base

# Local secrets (혹시 모를 PII 격리 폴더)
wiki/_broken/*.md
!wiki/_broken/.gitkeep

# Personal content — 시스템 템플릿/스키마만 git에 올림. 콘텐츠는 로컬 전용.
# raw/ 모든 마크다운 (개인 자료) — .gitkeep과 _attachments 디렉토리는 유지
raw/*.md
raw/_attachments/*
!raw/_attachments/.gitkeep

# wiki/ 콘텐츠 (raw에서 derive 되거나 사용자 query 결과)
wiki/concepts/*.md
wiki/entities/*.md
wiki/topics/**/*.md
wiki/summaries/*.md
wiki/queries/*.md
wiki/digests/*.md
wiki/_scratch/*.md

# 개인 볼트의 실제 카탈로그·로그·용어집도 제외.
# (git에는 templates/ 아래의 빈 버전만 올리고, ./scripts/init.sh 로 wiki/ 에 복사)
wiki/master-index.md
wiki/log.md
wiki/_meta/glossary.md

# 명시적으로 tracked되는 시스템 파일:
# - templates/{master-index,log,glossary}.md — 빈 부트스트랩 템플릿
# - wiki/open-questions.md — 템플릿 그대로 (개인 콘텐츠 없음)
# - wiki/_meta/{golden,stats}.md — eval 시나리오 / Dataview 쿼리 템플릿
# - scripts/init.sh — 첫 설치 부트스트랩
